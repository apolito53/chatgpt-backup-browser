{
  "compilerOptions": {
    "target": "ES2022",
    "module": "none",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "rootDir": "./src",
    "outDir": "./.tsbuild",
    "strict": false,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "removeComments": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}
